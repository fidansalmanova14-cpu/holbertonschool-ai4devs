{
  "openapi": "3.0.3",
  "info": {
    "title": "Network Device Inventory API",
    "version": "1.0.0",
    "description": "API for managing network assets with JWT security and 5+ CRUD operations."
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/devices": {
      "get": {
        "summary": "List devices",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      },
      "post": {
        "summary": "Create device",
        "responses": { "201": { "description": "Created" }, "400": { "description": "Bad Request" } }
      }
    },
    "/devices/{id}": {
      "get": { "summary": "Get device", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "OK" }, "404": { "description": "Not Found" } } },
      "put": { "summary": "Update device", "responses": { "200": { "description": "Updated" }, "404": { "description": "Not Found" } } },
      "delete": { "summary": "Delete device", "responses": { "204": { "description": "Deleted" }, "404": { "description": "Not Found" } } }
    },
    "/devices/search": {
      "get": {
        "summary": "Search devices",
        "parameters": [{ "name": "q", "in": "query", "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" }, "401": { "description": "Unauthorized" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
